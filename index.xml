<?xml version="1.0" encoding="utf-8"?>
<index version="1" name="Ostertoaster Clipboard Actions">
  <category name="Clipboard Actions">
    <reapack name="Ostertoaster_Copy selected track names to clipboard.lua" type="script" desc="Copy selected track names to clipboard">
      <metadata>
        <description><![CDATA[Copies the names of all selected tracks to the clipboard, one per line. Requires SWS extension.]]></description>
      </metadata>
      <version name="1.1" author="Ostertoaster" time="2026-03-06">
        <source main="main">https://raw.githubusercontent.com/bosterho/ostertoaster-clipboard-actions/master/Ostertoaster_Copy%20selected%20track%20names%20to%20clipboard.lua</source>
      </version>
    </reapack>
    <reapack name="Ostertoaster_Copy take markers to clipboard.lua" type="script" desc="Copy take markers to clipboard">
      <metadata>
        <description><![CDATA[Copies the positions of all take markers from the first selected item to the clipboard. Requires SWS extension.]]></description>
      </metadata>
      <version name="1.1" author="Ostertoaster" time="2026-03-06">
        <source main="main">https://raw.githubusercontent.com/bosterho/ostertoaster-clipboard-actions/master/Ostertoaster_Copy%20take%20markers%20to%20clipboard.lua</source>
      </version>
    </reapack>
    <reapack name="Ostertoaster_Copy take sources to clipboard.lua" type="script" desc="Copy take sources to clipboard">
      <metadata>
        <description><![CDATA[Copies the source file paths of all selected items to the clipboard. Handles reversed takes. Does not work on looped items. Requires SWS extension.]]></description>
      </metadata>
      <version name="1.1" author="Ostertoaster" time="2026-03-06">
        <source main="main">https://raw.githubusercontent.com/bosterho/ostertoaster-clipboard-actions/master/Ostertoaster_Copy%20take%20sources%20to%20clipboard.lua</source>
      </version>
    </reapack>
    <reapack name="Ostertoaster_Paste item lengths from clipboard.lua" type="script" desc="Paste item lengths from clipboard">
      <metadata>
        <description><![CDATA[Pastes lengths from clipboard (one per line) onto selected items. Values wrap if more items than lines. Requires SWS extension.]]></description>
      </metadata>
      <version name="1.1" author="Ostertoaster" time="2026-03-06">
        <source main="main">https://raw.githubusercontent.com/bosterho/ostertoaster-clipboard-actions/master/Ostertoaster_Paste%20item%20lengths%20from%20clipboard.lua</source>
        <source file="clipboard_lib.lua">https://raw.githubusercontent.com/bosterho/ostertoaster-clipboard-actions/master/clipboard_lib.lua</source>
      </version>
    </reapack>
    <reapack name="Ostertoaster_Paste item pans from clipboard.lua" type="script" desc="Paste item pans from clipboard">
      <metadata>
        <description><![CDATA[Pastes pan values from clipboard (one per line) onto selected items' active takes. Requires SWS extension.]]></description>
      </metadata>
      <version name="1.1" author="Ostertoaster" time="2026-03-06">
        <source main="main">https://raw.githubusercontent.com/bosterho/ostertoaster-clipboard-actions/master/Ostertoaster_Paste%20item%20pans%20from%20clipboard.lua</source>
        <source file="clipboard_lib.lua">https://raw.githubusercontent.com/bosterho/ostertoaster-clipboard-actions/master/clipboard_lib.lua</source>
      </version>
    </reapack>
    <reapack name="Ostertoaster_Paste take markers from clipboard.lua" type="script" desc="Paste take markers from clipboard">
      <metadata>
        <description><![CDATA[Pastes take marker positions from clipboard onto the first selected item's active take. Requires SWS extension.]]></description>
      </metadata>
      <version name="1.1" author="Ostertoaster" time="2026-03-06">
        <source main="main">https://raw.githubusercontent.com/bosterho/ostertoaster-clipboard-actions/master/Ostertoaster_Paste%20take%20markers%20from%20clipboard.lua</source>
